# Raw data — never commit datasets (see data/README.md for licenses/access)
data/**
!data/README.md
!data/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/
.pytest_cache/
.venv/
venv/

# Results/figures are regenerated; keep dirs, ignore bulky binaries
results/**
!results/.gitkeep
!results/*.csv
!results/*.json
figures/**
!figures/.gitkeep
!figures/*.png
!figures/*.pdf

# OS
.DS_Store

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.fmt
paper/*.log
.tex-home/
.tex-perllib/
.tectonic-cache/
.tectonic-home/
paper/build*.log
paper/fmt.log
paper/*.pdf
